# 多阶段构建：编译 + 运行
FROM maven:3.8.6-openjdk-8 AS builder
WORKDIR /build
COPY . .
RUN mvn clean package -DskipTests

FROM openjdk:8-jre-alpine
WORKDIR /app
COPY --from=builder /build/target/safe-edu-*.jar /app/safe-edu.jar
EXPOSE 8000
ENTRYPOINT ["java", "-jar", "safe-edu.jar", "--spring.profiles.active=dev"]
