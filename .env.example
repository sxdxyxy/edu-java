# Safe-Edu 环境变量配置
# 复制此文件为 .env 并填写实际值

# ============ 核心配置 ============
# JWT 密钥 (必须 - 256-bit 随机字符串)
TOKEN_SECRET=your-256-bit-secret-key-here

# ============ 腾讯云配置 ============
# COS 对象存储
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key

# 腾讯云通用配置
TENCENT_APP_ID=your-tencent-app-id
TENCENT_APP_SECRET=your-tencent-app-secret
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_FACE_LICENCE=your-face-licence-base64

# 腾讯云 VOD
VOD_SECRET_ID=${COS_SECRET_ID}
VOD_SECRET_KEY=${COS_SECRET_KEY}
VOD_PLAY_KEY=your-vod-play-key
VOD_APP_ID=1309460949
VOD_SUB_APP_ID=1500019533

# 腾讯云 Face
FACE_ACCESS_KEY_ID=${COS_SECRET_ID}
FACE_ACCESS_KEY_SECRET=${COS_SECRET_KEY}

# 腾讯云 OCR
OCR_ACCESS_KEY_ID=${COS_SECRET_ID}
OCR_ACCESS_KEY_SECRET=${COS_SECRET_KEY}

# ============ 短信配置 ============
SMS_ACCESS_KEY_ID=${COS_SECRET_ID}
SMS_ACCESS_KEY_SECRET=${COS_SECRET_KEY}
SMS_SIGN_NAME=子非鱼湖北信息科技
SMS_SDK_APP_ID=1400823707

# ============ 微信配置 ============
# 微信 PC 网页应用
WX_MP_WEB_APPID=your-wechat-web-appid
WX_MP_WEB_SECRET=your-wechat-web-secret

# 微信 APP 应用
WX_MP_APP_APPID=your-wechat-app-appid
WX_MP_APP_SECRET=your-wechat-app-secret

# 微信小程序
WX_MINIAPP_APPID=your-miniapp-appid
WX_MINIAPP_SECRET=your-miniapp-secret

# ============ Knife4j 文档配置 ============
KNIFE4J_BASIC_ENABLED=false
KNIFE4J_BASIC_USERNAME=
KNIFE4J_BASIC_PASSWORD=

# ============ 文件存储配置 ============
OSS_DOWNLOAD_PATH=/tmp/downloads
