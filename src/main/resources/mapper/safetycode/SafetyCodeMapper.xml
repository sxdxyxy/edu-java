<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyfishs.dawa.safetycode.mapper.SafetyCodeMapper">

    <!-- 安全码基础映射 -->
    <resultMap id="SafetyCodeResultMap" type="com.joyfishs.dawa.safetycode.entity.SafetyCode">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="projectId" column="project_id"/>
        <result property="orgId" column="org_id"/>
        <result property="code" column="code"/>
        <result property="color" column="color"/>
        <result property="status" column="status"/>
        <result property="validFrom" column="valid_from"/>
        <result property="validTo" column="valid_to"/>
        <result property="qrCodeData" column="qr_code_data"/>
        <result property="createdAt" column="create_time"/>
        <result property="updatedAt" column="update_time"/>
    </resultMap>

    <!-- 统计指定组织今天新增的安全码数量 -->
    <select id="countTodayNewCodesByOrg" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT COUNT(1) 
        FROM safety_codes sc
        INNER JOIN xm_person p ON sc.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND DATE(sc.create_time) = CURDATE()
    </select>

    <!-- 统计指定组织有效安全码数量 -->
    <select id="countValidCodesByOrg" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT COUNT(1) 
        FROM safety_codes sc
        INNER JOIN xm_person p ON sc.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND sc.status = 'active'
        AND sc.valid_to >= NOW()
    </select>

    <!-- 统计指定组织过期安全码数量 -->
    <select id="countExpiredCodesByOrg" parameterType="java.lang.Long" resultType="java.lang.Long">
        SELECT COUNT(1) 
        FROM safety_codes sc
        INNER JOIN xm_person p ON sc.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND sc.status = 'expired'
    </select>

</mapper>