<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyfishs.dawa.access.mapper.AccessRecordMapper">

    <!-- 准入记录基础映射 -->
    <resultMap id="AccessRecordResultMap" type="com.joyfishs.dawa.access.entity.AccessRecord">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="projectId" column="project_id"/>
        <result property="orgId" column="org_id"/>
        <result property="accessTime" column="access_time"/>
        <result property="exitTime" column="exit_time"/>
        <result property="accessType" column="access_type"/>
        <result property="safetyCodeColor" column="safety_code_color"/>
        <result property="gateId" column="gate_id"/>
        <result property="cameraSnapshot" column="camera_snapshot"/>
        <result property="location" column="location"/>
        <result property="remarks" column="remarks"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 统计指定组织今日入场人数 -->
    <select id="countTodayEntriesByOrg" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM access_records ar
        INNER JOIN xm_person p ON ar.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND DATE(ar.access_time) = CURDATE()
        AND ar.access_type = 'entry'
    </select>

    <!-- 统计指定组织今日出场人数 -->
    <select id="countTodayExitsByOrg" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM access_records ar
        INNER JOIN xm_person p ON ar.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND DATE(ar.exit_time) = CURDATE()
        AND ar.exit_time IS NOT NULL
    </select>

    <!-- 统计指定组织当前在场人数 -->
    <select id="countCurrentOnsiteByOrg" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM access_records ar
        INNER JOIN xm_person p ON ar.user_id = p.id
        WHERE p.org_id = #{orgId}
        AND ar.access_time IS NOT NULL
        AND ar.exit_time IS NULL
    </select>

</mapper>