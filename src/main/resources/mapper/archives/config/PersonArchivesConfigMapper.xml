<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.joyfishs.dawa.archives.config.mapper.PersonArchivesConfigMapper">

    <resultMap id="BaseResultMap" type="com.joyfishs.dawa.archives.config.entity.PersonArchivesConfig">
        <id column="id" property="id"/>
        <result column="work_type" property="workType"/>
        <result column="config_name" property="configName"/>
        <result column="config_code" property="configCode"/>
        <result column="org_id" property="orgId"/>
        <result column="template_fields" property="templateFields"/>
        <result column="document_template_url" property="documentTemplateUrl"/>
        <result column="document_template_name" property="documentTemplateName"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="is_active" property="isActive"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectByWorkTypeAndOrgId" resultMap="BaseResultMap">
        SELECT * FROM person_archives_config
        WHERE work_type = #{workType}
          AND org_id = #{orgId}
          AND is_active = 1
        ORDER BY sort_order ASC
    </select>

</mapper>
